POSTGRES_DB=maintenance_db
POSTGRES_USER=maintenance_user
POSTGRES_PASSWORD=change-this-strong-db-password

DATABASE_URL=postgresql://maintenance_user:change-this-strong-db-password@postgres:5432/maintenance_db
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# if more than 1 it should be separated by a comma 
CORS_ORIGINS=https://your-domain.com

# Set to false if you do not want automatic admin seeding
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
B_D=change-this-backdoor-password

GRAFANA_ADMIN_PASSWORD=change-this-grafana-password